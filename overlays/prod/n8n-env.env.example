# Prod – copy to n8n-env.env and set real values. Do not commit n8n-env.env.
# Same DB/Redis as dev in this setup; override any key here for prod-only values.
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=n8n-postgres.c4n0m4skmzkn.us-east-1.rds.amazonaws.com
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=n8n
DB_POSTGRESDB_USER=root
DB_POSTGRESDB_PASSWORD=CHANGE_ME
DB_POSTGRESDB_SSL=true
DB_POSTGRESDB_SSL_MODE=require
DB_POSTGRESDB_SSL_REJECT_UNAUTHORIZED=false
N8N_ENCRYPTION_KEY=CHANGE_ME
N8N_HOST=0.0.0.0
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_SECURE_COOKIE=false
EXECUTIONS_MODE=queue
QUEUE_BULL_REDIS_HOST=master.n8n-redis.nr1pf5.use1.cache.amazonaws.com
QUEUE_BULL_REDIS_PORT=6379
QUEUE_BULL_REDIS_TLS=true
QUEUE_BULL_REDIS_TLS_REJECT_UNAUTHORIZED=false
